@model IEnumerable<MobileShopOrderMangement.Models.ViewModels.OrderMasterViewModel>

@{
    ViewBag.Title = "Orders";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2>
                <i class="fas fa-shopping-bag"></i> Orders
            </h2>
        </div>
        <div class="col-md-4 text-right">
            @Html.ActionLink("Place New Order", "Create", null, new { @class = "btn btn-success btn-lg" })
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle"></i> @TempData["ErrorMessage"]
            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
    }

    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-bordered">
                <thead class="thead-dark">
                    <tr>
                        <th class="text-center"><i class="fas fa-hashtag"></i> Order ID</th>
                        <th><i class="fas fa-user"></i> @Html.DisplayNameFor(model => model.CustomerName)</th>
                        <th><i class="fas fa-phone"></i> @Html.DisplayNameFor(model => model.ContactNumber)</th>
                        <th><i class="fas fa-calendar"></i> @Html.DisplayNameFor(model => model.OrderDate)</th>
                        <th class="text-right"><i class="fas fa-money-bill"></i> @Html.DisplayNameFor(model => model.TotalAmount)</th>
                        <th style="width: 200px;" class="text-center"><i class="fas fa-cog"></i> Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-center">
                                <strong>#@Html.DisplayFor(modelItem => item.OrderId)</strong>
                            </td>
                            <td>@Html.DisplayFor(modelItem => item.CustomerName)</td>
                            <td>@Html.DisplayFor(modelItem => item.ContactNumber)</td>
                            <td>@Html.DisplayFor(modelItem => item.OrderDate)</td>
                            <td class="text-right">
                                <strong class="text-success">৳ @Html.DisplayFor(modelItem => item.TotalAmount)</strong>
                            </td>
                            <td class="text-center">
                                @Html.ActionLink("Edit", "Edit", new { id = item.OrderId }, new { @class = "btn btn-sm btn-warning" })
                                @Html.ActionLink("Delete", "Delete", new { id = item.OrderId }, new { @class = "btn btn-sm btn-danger" })
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <i class="fas fa-info-circle"></i> No orders found. <strong>@Html.ActionLink("Create one now", "Create")</strong>
        </div>
    }
</div>
