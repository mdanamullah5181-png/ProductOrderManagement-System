@model MobileShopOrderMangement.Models.ViewModels.OrderMasterViewModel

@{
    ViewBag.Title = "Edit Order";
}

<div class="container mt-4">
    <h2>Edit Order #@Model.OrderId</h2>
    <hr />

    @using (Html.BeginForm("Edit", "Order", FormMethod.Post, new { @id = "orderForm" }))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(model => model.OrderId)
        @Html.HiddenFor(model => model.CustomerId)
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

        <!-- Section 1: Customer Information -->
        <div class="card mb-4">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0">1. Customer Information</h4>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group">
                            @Html.LabelFor(model => model.CustomerName)
                            @Html.EditorFor(model => model.CustomerName, new { htmlAttributes = new { @class = "form-control" } })
                            @Html.ValidationMessageFor(model => model.CustomerName, "", new { @class = "text-danger" })
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            @Html.LabelFor(model => model.ContactNumber)
                            @Html.EditorFor(model => model.ContactNumber, new { htmlAttributes = new { @class = "form-control" } })
                            @Html.ValidationMessageFor(model => model.ContactNumber, "", new { @class = "text-danger" })
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            @Html.LabelFor(model => model.ContactAddress)
                            @Html.TextAreaFor(model => model.ContactAddress, new { @class = "form-control", rows = 2 })
                            @Html.ValidationMessageFor(model => model.ContactAddress, "", new { @class = "text-danger" })
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Section 2: Add Products -->
        <div class="card mb-4">
            <div class="card-header bg-success text-white">
                <h4 class="mb-0">2. Add/Update Products</h4>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-3">
                        <div class="form-group">
                            <label>Product Category</label>
                            <select id="ddlCategory" class="form-control">
                                <option value="">-- Select Category --</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label>Product</label>
                            <select id="ddlProduct" class="form-control">
                                <option value="">-- Select Product --</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="form-group">
                            <label>Order Quantity</label>
                            <input type="number" id="txtOrderQuantity" class="form-control" min="1" value="1" />
                            <small id="availableQtyText" class="text-muted"></small>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="form-group">
                            <label>Unit</label>
                            <input type="text" id="txtOrderUnit" class="form-control" readonly />
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="form-group">
                            <label>Unit Price</label>
                            <input type="text" id="txtUnitPrice" class="form-control" readonly />
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-12">
                        <button type="button" id="btnAddProduct" class="btn btn-primary">
                            <i class="fa fa-plus"></i> Add Product
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Section 3: Order Details List -->
        <div class="card mb-4">
            <div class="card-header bg-info text-white">
                <h4 class="mb-0">3. Order Details</h4>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-bordered" id="tblOrderDetails">
                        <thead class="thead-light">
                            <tr>
                                <th>Category</th>
                                <th>Product</th>
                                <th>Quantity</th>
                                <th>Unit</th>
                                <th>Unit Price</th>
                                <th>Amount</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody id="orderDetailsBody">
                            <tr id="noDataRow">
                                <td colspan="7" class="text-center text-muted">No products added yet</td>
                            </tr>
                        </tbody>
                        <tfoot>
                            <tr>
                                <th colspan="5" class="text-right">Total Amount:</th>
                                <th id="totalAmount">0.00</th>
                                <th></th>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>

        <!-- Hidden field for order details -->
        <input type="hidden" id="hdnOrderDetails" name="OrderDetailsListJson" />

        <!-- Submit Button -->
        <div class="form-group">
            <button type="submit" class="btn btn-lg btn-success">
                <i class="fa fa-save"></i> Update Order
            </button>
            @Html.ActionLink("Back to Orders", "Index", null, new { @class = "btn btn-lg btn-secondary" })
        </div>
    }
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")

    <script type="text/javascript">
        var orderDetailsList = @Html.Raw(Json.Encode(Model.OrderDetailsList ?? new List<MobileShopOrderMangement.Models.ViewModels.OrderDetailsViewModel>()));

        $(document).ready(function () {
            loadCategories();
            renderOrderDetailsTable();

            // Category change event
            $('#ddlCategory').change(function () {
                var categoryId = $(this).val();
                if (categoryId) {
                    loadProducts(categoryId);
                } else {
                    $('#ddlProduct').html('<option value="">-- Select Product --</option>');
                    clearProductFields();
                }
            });

            // Product change event
            $('#ddlProduct').change(function () {
                var productId = $(this).val();
                if (productId) {
                    loadProductDetails(productId);
                } else {
                    clearProductFields();
                }
            });

            // Add product button click
            $('#btnAddProduct').click(function () {
                addProductToOrder();
            });

            // Form submit
            $('#orderForm').submit(function (e) {
                if (orderDetailsList.length === 0) {
                    e.preventDefault();
                    alert('Please add at least one product to the order.');
                    return false;
                }

                var orderDetailsJson = JSON.stringify(orderDetailsList);
                $('#hdnOrderDetails').val(orderDetailsJson);
            });
        });

        function loadCategories() {
            var categories = @Html.Raw(Json.Encode(ViewBag.ProductCategories));
            var options = '<option value="">-- Select Category --</option>';
            $.each(categories, function (index, category) {
                options += '<option value="' + category.Value + '">' + category.Text + '</option>';
            });
            $('#ddlCategory').html(options);
        }

        function loadProducts(categoryId) {
            $.ajax({
                url: '@Url.Action("GetProductsByCategory", "Product")',
                type: 'GET',
                data: { categoryId: categoryId },
                success: function (products) {
                    var options = '<option value="">-- Select Product --</option>';
                    $.each(products, function (index, product) {
                        options += '<option value="' + product.ProductId + '" data-unit="' + product.Unit + '" data-price="' + product.UnitPrice + '" data-qty="' + product.AvailableQuantity + '">' + product.ProductName + '</option>';
                    });
                    $('#ddlProduct').html(options);
                    clearProductFields();
                },
                error: function () {
                    alert('Error loading products');
                }
            });
        }

        function loadProductDetails(productId) {
            $.ajax({
                url: '@Url.Action("GetProductDetails", "Order")',
                type: 'GET',
                data: { productId: productId },
                success: function (response) {
                    if (response.success) {
                        $('#txtOrderUnit').val(response.unit);
                        $('#txtUnitPrice').val(response.unitPrice.toFixed(2));
                        $('#txtOrderQuantity').attr('max', response.availableQuantity);
                        $('#availableQtyText').text('Available: ' + response.availableQuantity);
                    }
                },
                error: function () {
                    alert('Error loading product details');
                }
            });
        }

        function clearProductFields() {
            $('#txtOrderUnit').val('');
            $('#txtUnitPrice').val('');
            $('#txtOrderQuantity').val('1');
            $('#availableQtyText').text('');
        }

        function addProductToOrder() {
            var categoryId = $('#ddlCategory').val();
            var categoryName = $('#ddlCategory option:selected').text();
            var productId = $('#ddlProduct').val();
            var productName = $('#ddlProduct option:selected').text();
            var orderQuantity = parseInt($('#txtOrderQuantity').val());
            var orderUnit = $('#txtOrderUnit').val();
            var unitPrice = parseFloat($('#txtUnitPrice').val());
            var availableQty = parseInt($('#ddlProduct option:selected').data('qty'));

            if (!categoryId) {
                alert('Please select a category');
                return;
            }
            if (!productId) {
                alert('Please select a product');
                return;
            }
            if (!orderQuantity || orderQuantity <= 0) {
                alert('Please enter a valid quantity');
                return;
            }

            var existingIndex = -1;
            for (var i = 0; i < orderDetailsList.length; i++) {
                if (orderDetailsList[i].ProductId === parseInt(productId)) {
                    existingIndex = i;
                    break;
                }
            }

            var amount = orderQuantity * unitPrice;

            if (existingIndex !== -1) {
                orderDetailsList[existingIndex].OrderQuantity = orderQuantity;
                orderDetailsList[existingIndex].Amount = amount;
            } else {
                var orderDetail = {
                    OrderDetailsId: 0,
                    OrderId: @Model.OrderId,
                    ProductCategoryId: parseInt(categoryId),
                    CategoryName: categoryName,
                    ProductId: parseInt(productId),
                    ProductName: productName,
                    OrderQuantity: orderQuantity,
                    OrderUnit: orderUnit,
                    UnitPrice: unitPrice,
                    Amount: amount,
                    AvailableQuantity: availableQty
                };
                orderDetailsList.push(orderDetail);
            }

            renderOrderDetailsTable();
            clearForm();
        }

        function renderOrderDetailsTable() {
            var tbody = $('#orderDetailsBody');
            tbody.empty();

            if (orderDetailsList.length === 0) {
                tbody.append('<tr id="noDataRow"><td colspan="7" class="text-center text-muted">No products added yet</td></tr>');
                $('#totalAmount').text('0.00');
                return;
            }

            var total = 0;
            $.each(orderDetailsList, function (index, item) {
                var row = '<tr>' +
                    '<td>' + item.CategoryName + '</td>' +
                    '<td>' + item.ProductName + '</td>' +
                    '<td>' + item.OrderQuantity + '</td>' +
                    '<td>' + item.OrderUnit + '</td>' +
                    '<td>' + item.UnitPrice.toFixed(2) + '</td>' +
                    '<td>' + item.Amount.toFixed(2) + '</td>' +
                    '<td>' +
                    '<button type="button" class="btn btn-sm btn-warning" onclick="editProduct(' + index + ')">Edit</button> ' +
                    '<button type="button" class="btn btn-sm btn-danger" onclick="deleteProduct(' + index + ')">Delete</button>' +
                    '</td>' +
                    '</tr>';
                tbody.append(row);
                total += item.Amount;
            });

            $('#totalAmount').text('' + total.toFixed(2));
        }

        function editProduct(index) {
            var item = orderDetailsList[index];
            $('#ddlCategory').val(item.ProductCategoryId).trigger('change');

            setTimeout(function () {
                $('#ddlProduct').val(item.ProductId).trigger('change');
                $('#txtOrderQuantity').val(item.OrderQuantity);
            }, 500);

            orderDetailsList.splice(index, 1);
            renderOrderDetailsTable();
        }

        function deleteProduct(index) {
            if (confirm('Are you sure you want to remove this product?')) {
                orderDetailsList.splice(index, 1);
                renderOrderDetailsTable();
            }
        }

        function clearForm() {
            $('#ddlCategory').val('');
            $('#ddlProduct').html('<option value="">-- Select Product --</option>');
            clearProductFields();
        }
    </script>
}

<style>
    .card-header h4 {
        margin: 0;
    }

    #tblOrderDetails tbody tr td {
        vertical-align: middle;
    }
</style>
