@model MobileShopOrderMangement.Models.ViewModels.ProductViewModel

@{
    ViewBag.Title = "Delete Product";
}

<div class="container mt-4">
    <h2>Delete Product</h2>
    <hr />

    <h3 class="text-danger">Are you sure you want to delete this product?</h3>
    <div>
        <dl class="row">
            @if (!string.IsNullOrEmpty(Model.ProductImage))
            {
                <dt class="col-sm-3">Image</dt>
                <dd class="col-sm-9">
                    <img src="@Url.Content("~/Images/" + Model.ProductImage)" alt="Product" style="max-width: 200px; max-height: 200px;" class="img-thumbnail" />
                </dd>
            }

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.ProductName)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.ProductName)</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.CategoryName)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.CategoryName)</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Unit)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Unit)</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.UnitPrice)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.UnitPrice)</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.AvailableQuantity)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.AvailableQuantity)</dd>
        </dl>

        @using (Html.BeginForm("Delete", "Product", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(model => model.ProductId)

            <div class="form-group">
                <input type="submit" value="Delete" class="btn btn-danger" />
                @Html.ActionLink("Back to List", "Index", null, new { @class = "btn btn-secondary" })
            </div>
        }
    </div>
</div>
